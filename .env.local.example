# ─────────────────────────────────────────────
# PlanIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# Supabase (get from: https://supabase.com/dashboard → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# App version label (shown in the app UI)
NEXT_PUBLIC_APP_VERSION=v1.0.0-early-access

# ─────────────────────────────────────────────
# NOTE: The Anthropic API key is NOT stored here.
# It lives as a Supabase secret, set via:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# This keeps it server-side only, never exposed to the browser.
# ─────────────────────────────────────────────

# ── Sentry (crash reporting) ──────────────────────────────────────────────────
# Get your DSN from https://sentry.io → Your Project → Settings → Client Keys
# Without this, Sentry is completely disabled (safe to deploy without it).
NEXT_PUBLIC_SENTRY_DSN=

# Required only for source map uploads during CI/CD builds:
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=planiq
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── PostHog (analytics) ───────────────────────────────────────────────────────
# Get these from https://us.posthog.com → Your Project → Settings → API Keys
# Without these, all analytics calls are silent no-ops.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Generate once with: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
# NEXT_PUBLIC_ prefix = safe to send to browser (public key only)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
# Keep the private key server-side only — never expose in client code
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
# The mailto: contact in VAPID headers (any valid email)
VAPID_MAILTO=hello@planiq.app

# ── Cron Security ─────────────────────────────────────────────────────────────
# Random secret Vercel injects when calling /api/notifications/cron
# Generate with: openssl rand -hex 32
CRON_SECRET=YOUR_RANDOM_CRON_SECRET

# ── Supabase Service Role (server-side only, NEVER use NEXT_PUBLIC_ prefix) ──
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
